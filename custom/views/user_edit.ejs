<% this.title = '修改资料'; %>
<% include header %>
<div class="padding">
    <div class="ui <% if (error_info === '') { %>success<% } else { %>error<% } %> message" id="error" <% if (error_info === null) { %>hidden<% } %>>
      <% if (error_info !== null) {
          if (error_info === '') error_info = '修改成功。';
      %>
      	<p id="error_info"><%= error_info %></p>
      <% } %>
    </div>
		<form id="form" action="<%= syzoj.utils.makeUrl(['user', edited_user.id, 'edit']) %>" method="post" onsubmit="return check()">
      <div class="ui form">
      <div class="field">
	    	<label for="username">用户名</label>
	    	<input type="text" id="username" name="username" value="<%= edited_user.username %>"<% if (!user.allowedManage) { %> readonly<% } %>>
	    </div>
      <div class="field">
	    	<label for="sex">性别</label>
	    	<select class="ui dropdown" name="sex">
          <option value="0" <%= edited_user.sex == 0 ? 'selected': '' %>>其它</option>
          <option value="1" <%= edited_user.sex == 1 ? 'selected': '' %>>男</option>
          <option value="-1" <%= edited_user.sex == -1 ? 'selected': '' %>>女</option>
        </select>
	    </div>
	    <div class="field">
	    	<label for="email">Email</label>
	    	<input class="font-content" type="email" id="email" name="email" value="<%= edited_user.email %>"<% if (!user.allowedManage) { %> readonly<% } %>>
	    </div>
	    <% if (typeof edited_user !== 'undefined' && edited_user.id === user.id) { %>
            <div class="field">
            <label>邮箱验证状态</label>
            <% if (user.is_email_verified || (syzoj.verifiedUserIds && syzoj.verifiedUserIds.has(user.id))) { %>
                <div class="ui green message" style="margin-top: 5px;">
                    <i class="check circle icon"></i>
                    <b>已验证</b> · 你已完成邮箱验证。
                </div>
            <% } else { %>
                <div class="ui yellow message" style="margin-top: 5px;">
                    <i class="warning circle icon"></i>
                    <b>邮箱尚未验证。</b>未验证的账号无法使用部分功能（如投稿题解、发送站内信）。
                    <div style="margin-top: 10px;">
                    <a class="ui small primary button" href-post="/email/send-verification">
                        <i class="envelope icon"></i> 发送验证邮件
                    </a>
                </div>
            </div>
            <% } %>
        </div>
        <% } %>
        
      <div class="inline field">
        <label class="ui header">公开 Email</label>
        <div class="ui toggle checkbox">
          <input id="public_email" name="public_email" type="checkbox" <% if (edited_user.public_email) { %> checked<% } %>>
          <label>　</label>
        </div>
	    </div>
      <div class="inline field">
        <label class="ui header">默认显示格式化后的代码（如果可用）</label>
        <div class="ui toggle checkbox">
          <input id="prefer_formatted_code" name="prefer_formatted_code" type="checkbox" <% if (edited_user.prefer_formatted_code) { %> checked<% } %>>
          <label>　</label>
        </div>
      </div>
      <div class="field">
      <label for="information">个性签名</label>
        <textarea class="markdown-edit" rows="5" id="information" name="information"><%= edited_user.information %></textarea>
      </div>
      <div class="field">
      <label class="ui header">密码</label>
        <input type="password" placeholder="原密码（留空则不修改）" name="old_password" id="old_password">
      </div>
      <div class="two fields" id="new_password_field">
        <div class="field">
          <input type="password" placeholder="新密码" name="new_password" id="password1">
        </div>
        <div class="field">
          <input type="password" placeholder="确认密码" id="password2">
        </div>
      </div>
      <%
      let allowedManagePrivilege = user && user.is_admin;
      %>
      <div class="inline field">
        <label class="ui header">权限</label>
        <div class="ui toggle disabled checkbox" style="margin-right: 20px; ">
          <input disabled="disabled" type="checkbox" <% if (edited_user.is_admin) { %> checked<% } %>>
          <label>全站管理员</label>
        </div>
        <div class="ui toggle <% if (!allowedManagePrivilege) { %>disabled <% } %>checkbox checkbox_privilege" data-name="manage_problem" style="margin-right: 20px; ">
          <input <% if (!allowedManagePrivilege) { %>disabled="disabled" <% } %>type="checkbox"<% if (edited_user.privileges.includes('manage_problem')) { %> checked<% } %>>
          <label>管理题目</label>
        </div>
        <div class="ui toggle <% if (!allowedManagePrivilege) { %>disabled <% } %>checkbox checkbox_privilege" data-name="manage_problem_tag" style="margin-right: 20px; ">
          <input <% if (!allowedManagePrivilege) { %>disabled="disabled" <% } %>type="checkbox"<% if (edited_user.privileges.includes('manage_problem_tag')) { %> checked<% } %>>
          <label>管理题目标签</label>
        </div>
        <div class="ui toggle <% if (!allowedManagePrivilege) { %>disabled <% } %>checkbox checkbox_privilege" data-name="manage_user">
          <input <% if (!allowedManagePrivilege) { %>disabled="disabled" <% } %>type="checkbox"<% if (edited_user.privileges.includes('manage_user')) { %> checked<% } %>>
          <label>管理用户</label>
        </div>
      </div>
      <div style="text-align: center; margin-top: 30px; ">
        <button id="submit_button" type="submit" class="ui blue labeled icon button"><i class="ui icon edit"></i>修改</button>
        <a href="<%= syzoj.utils.makeUrl(['user', edited_user.id]) %>" class="ui labeled icon button"><i class="ui icon angle left"></i>返回</a>
      </div>
      </div>
		</form>
<%
    let _tagState = (typeof myTagState !== 'undefined') ? myTagState : null;
    let _tagIsCheater = (typeof myTagIsCheater !== 'undefined') ? myTagIsCheater : false;
    %>
    <% if (_tagState && _tagState.hasPermission) { %>
      <div class="ui segment" style="margin-top: 15px;">
        <h4 style="margin-top: 0;"><i class="id badge icon"></i> 用户名牌子</h4>
        <p style="color: #666; font-size: 0.92em;">
          牌子会显示在你用户名的右侧。颜色与用户名颜色一致。最多 12 字符。
          <% if (_tagState.isAutoFromAdmin) { %>
            <br><i class="info circle icon"></i>
            <span style="color: #2185d0;">您因拥有管理权限自动获得 tag 权限。</span>
          <% } %>
        </p>

        <% if (_tagIsCheater) { %>
          <div class="ui yellow message" style="margin-bottom: 12px;">
            <i class="warning sign icon"></i>
            <b>当前您的荣誉牌子被作弊者身份覆盖，在站内将显示为「作弊者」棕色标签。</b>
            您依然可以编辑下方设置，作弊者标记被撤销后将立即恢复显示。
          </div>
        <% } %>

        <form id="my-tag-form" style="margin: 0;">
          <div class="ui form">
            <div class="field">
              <label>牌子文字</label>
              <input type="text" id="my-tag-text-input" maxlength="12"
                     value="<%= _tagState.record ? (_tagState.record.tag_text || '') : '管理员' %>"
                     placeholder="<%= _tagState.isAutoFromAdmin ? '管理员' : '请填写要显示的文字...' %>"
                     style="max-width: 220px;">
              <span style="margin-left: 10px; color: #999; font-size: 0.85em;">
                <span id="my-tag-char-count">0</span> / 12
              </span>
            </div>
            <div class="field">
              <div class="ui toggle checkbox">
                <input type="checkbox" id="my-tag-visible-input"
                       <% if (!_tagState.record || _tagState.record.is_visible !== false) { %>checked<% } %>>
                <label>在站内展示此牌子</label>
              </div>
            </div>
            <button type="button" class="ui primary button" id="my-tag-save-btn">
              <i class="save icon"></i> 保存牌子设置
            </button>
            <span id="my-tag-status" style="margin-left: 12px;"></span>
          </div>
        </form>

        <script>
        (function() {
          var input = document.getElementById('my-tag-text-input');
          var visible = document.getElementById('my-tag-visible-input');
          var btn = document.getElementById('my-tag-save-btn');
          var status = document.getElementById('my-tag-status');
          var counter = document.getElementById('my-tag-char-count');

          function updateCount() { counter.textContent = input.value.length; }
          input.addEventListener('input', updateCount);
          updateCount();

          btn.addEventListener('click', function() {
            btn.disabled = true;
            status.textContent = '保存中...';
            status.style.color = '#888';

            var params = new URLSearchParams();
            params.append('tag_text', input.value);
            params.append('is_visible', visible.checked ? 'true' : 'false');

            fetch('/api/my-tag', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
              body: params.toString()
            })
              .then(function(r) { return r.json(); })
              .then(function(d) {
                if (d.ok) {
                  status.textContent = '保存成功! 刷新页面后生效';
                  status.style.color = '#21ba45';
                } else {
                  status.textContent = '失败: ' + (d.message || '未知错误');
                  status.style.color = '#db2828';
                }
                btn.disabled = false;
              })
              .catch(function(e) {
                status.textContent = '网络错误: ' + e.message;
                status.style.color = '#db2828';
                btn.disabled = false;
              });
          });
        })();
        </script>
      </div>
    <% } else if (typeof edited_user !== 'undefined' && edited_user.id === user.id && _tagState && _tagState.isDisabled) { %>
      <div class="ui segment" style="margin-top: 15px;">
        <h4 style="margin-top: 0;"><i class="id badge icon"></i> 用户名牌子</h4>
        <div class="ui red message">
          <i class="ban icon"></i>
          您的牌子使用权限已被超级管理员撤销
          <% if (_tagState.record && _tagState.record.disabled_reason) { %>
            <br><span style="color: #888;">原因： <%= _tagState.record.disabled_reason %></span>
          <% } %>
        </div>
      </div>
    <% } %>
    <% if (typeof edited_user !== 'undefined' && edited_user.id === user.id) { %>
      <%
      let hideHitCurrent = (typeof syzoj.userHitHidden !== 'undefined' && syzoj.userHitHidden.has(edited_user.id));
      %>
      <div class="ui divider" style="margin-top: 40px;"></div>
      <h3 style="margin-top: 30px;"><i class="bullseye icon"></i> Hit 值显示设置</h3>
      <form method="post" action="<%= syzoj.utils.makeUrl(['user', edited_user.id, 'hit-setting']) %>" class="ui form" style="margin-top: 15px;">
        <div class="inline field">
          <div class="ui toggle checkbox">
            <input type="checkbox" name="hide_hit" id="hide_hit_toggle" <% if (hideHitCurrent) { %>checked<% } %>>
            <label for="hide_hit_toggle">在我的主页隐藏 Hit 值卡片</label>
          </div>
        </div>
        <div style="color: #888; font-size: 0.9em; margin-top: 6px; padding-left: 30px;">
          隐藏后，他人访问你的主页将看不到 Hit 卡片。Hit 值本身仍会被系统计算、并影响用户名颜色档。
          <a href="/help/hit-value">了解 Hit 值</a>
        </div>
        <button type="submit" class="ui small primary button" style="margin-top: 15px;">保存 Hit 设置</button>
      </form>
    <% } %>
	</div>
</div>
<script>
var bakDefine = (typeof define !== "undefined") ? define : undefined;
define = undefined;
</script>
<script src="<%- lib('blueimp-md5/2.10.0/js/md5.min.js') %>"></script>
<script>
define = bakDefine;
</script>
<script type="text/javascript">
function make_md5(tag) {
	if (tag.val()) {
		tag.val(md5(tag.val() + "syzoj2_xxx"));
	}
}
function check() {
	old_password = $("#old_password");
	password1 = $("#password1");
	password2 = $("#password2");
	if ($("#old_password").val() && password1.val() != password2.val()) {
		$("#error").removeClass("success");
		$("#error").removeClass("error");
		$("#error").addClass("error");
		$("#error_info").html("两次输入的密码不一致。");
		$("#error").show();
		return false;
	}
	make_md5(old_password);
	make_md5(password1);
	make_md5(password2);

<% if (allowedManagePrivilege) { %>
  $('.checkbox_privilege').each(function () {
    if ($(this).checkbox('is checked')) {
      var name = $(this).data('name');

      var elem = document.createElement('input');
      elem.type = 'hidden';
      elem.value = name;
      elem.name = 'privileges';
      document.getElementById('form').appendChild(elem);
    }
  });
<% } %>

	return true;
}
</script>
<script>
$(function () {
	$('.ui.dropdown:not(.simple)').dropdown();
	$('.ui.toggle.checkbox').checkbox();
});
</script>
<% include footer %>