      m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
      })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');

      ga('create', '<%= syzoj.config.google_analytics %>', 'auto');
      ga('send', 'pageview');

    </script>
    <% } %>
    <%
    // ============ 用户名颜色 tier 注入(给 Vue 组件用)============
    let _tierMap = {};
    function _calcTier(userId, isAdminUser) {
        if (isAdminUser) return 'admin';
        if (syzoj.adminUserIds && syzoj.adminUserIds.has(userId)) return 'admin';
        if (syzoj.userHitScores && syzoj.userHitScores.has(userId)) {
            let s = syzoj.userHitScores.get(userId);
            let h = s.total || 0;
            if (h >= 350) return 'red';
            if (h >= 280) return 'orange';
            if (h >= 200) return 'green';
            if (h >= 100) return 'blue';
            return 'gray';
        }
        return 'default';
    }
    // 1. admin 用户(优先级最高)
    if (syzoj.adminUserIds) {
        for (let uid of syzoj.adminUserIds) _tierMap[uid] = 'admin';
    }
    // 2. Hit 值非 default 档的用户
    if (syzoj.userHitScores) {
        for (let [uid, scoreData] of syzoj.userHitScores) {
            if (_tierMap[uid] === 'admin') continue; // admin 优先级更高
            let t = _calcTier(uid, false);
            if (t !== 'default' && t !== 'gray') {
                // 只塞非 gray 档的(gray 跟 default 同色,省点字节)
                _tierMap[uid] = t;
            }
        }
    }
%>
<%
let _cheatedIds = [];
let _cancelledIds = [];
let _cheaterUids = [];
if (syzoj.cheatedJudgeIds) for (let id of syzoj.cheatedJudgeIds) _cheatedIds.push(id);
if (syzoj.cancelledJudgeIds) for (let id of syzoj.cancelledJudgeIds) _cancelledIds.push(id);
if (syzoj.cheaterUserIds) for (let id of syzoj.cheaterUserIds) _cheaterUids.push(id);

let _userTagsObj = {};
if (syzoj.userTags) {
  for (let [uid, info] of syzoj.userTags) {
    _userTagsObj[uid] = { text: info.text, tier: info.tier };
  }
}
%>
<script>
window.__SYZOJ_USER_TIERS = <%- JSON.stringify(_tierMap) %>;
window.__SYZOJ_CHEATED_JUDGE_IDS = <%- JSON.stringify(_cheatedIds) %>;
window.__SYZOJ_CANCELLED_JUDGE_IDS = <%- JSON.stringify(_cancelledIds) %>;
window.__SYZOJ_CHEATER_USER_IDS = <%- JSON.stringify(_cheaterUids) %>;
window.__SYZOJ_USER_TAGS = <%- JSON.stringify(_userTagsObj) %>;
</script>
</head>
<body style="position: relative; margin-top: 49px; height: calc(100% - 49px); overflow-y: overlay; ">
    <div class="ui fixed borderless menu" style="position: fixed; height: 49px; ">
        <div class="ui container">
            <a class="header item" href="/" style="display: flex; align-items: center; gap: 8px;">
              <img src="/self/logo.png" style="height: 48px; width: auto;" alt="logo">
              <span style="font-family: 'Exo 2'; font-size: 1.5em; font-weight: 600;"><%= syzoj.config.title %></span>
            </a>
            <a class="item<% if (active === '') { %> active<% } %>" href="/"><i class="home icon"></i> 首页</a>
            <a class="item<% if (active.startsWith('problem')) { %> active<% } %>" href="/problems"><i class="list icon"></i> 题库</a>
            <a class="item<% if (active.startsWith('contest')) { %> active<% } %>" href="/contests"><i class="calendar icon"></i> 比赛</a>
            <a class="item<% if (active.startsWith('submission')) { %> active<% } %>" href="/submissions"><i class="tasks icon"></i> 评测</a>
            <a class="item<% if (active.startsWith('ranklist')) { %> active<% } %>" href="/ranklist"><i class="signal icon"></i> 排名</a>
            <a class="item<% if (active.startsWith('discussion') || active.startsWith('article')) { %> active<% } %>" href="/discussion/global"><i class="comments icon"></i> 讨论</a>
            <a class="item<% if (active.startsWith('help')) { %> active<% } %>" href="/help"><i class="help circle icon"></i> 帮助</a>
            <a class="item<% if (active.startsWith('tags')) { %> active<% } %>" href="/tags" style="margin-right: 30px;"><i class="tags icon"></i> 标签</a>
            <% if (user) { %>
                <a class="item" href="<%= syzoj.utils.makeUrl(['tickets']) %>"><i class="ticket icon"></i>工单</a>
            <% } %>
            <% if (typeof contest !== 'undefined' && contest && contest.id) { %>
              <a id="back_to_contest" class="item" href="<%= syzoj.utils.makeUrl(['contest', contest.id]) %>"><i class="arrow left icon"></i> 返回比赛</a>
            <% } %>
            <div class="right menu">
              <% if (user) { %>
              <a class="item" href="/messages" title="站内信" style="position: relative;">
                <i class="envelope outline icon" style="margin: 0;"></i>
                <% if (typeof unreadMessagesCount !== 'undefined' && unreadMessagesCount > 0) { %>
                <div class="floating ui red tiny circular label" style="top: 5px; left: 75%; padding: 4px 6px;"><%= unreadMessagesCount %></div>
                <% } %>
              </a>
              <a href="<%= syzoj.utils.makeUrl(['user', user.id]) %>" style="color: inherit; ">
              <div class="ui simple dropdown item">
                <%= user.username %><% if (user.nameplate) { %><%- user.nameplate %><% } %> <i class="dropdown icon"></i>
                <div class="menu">
                  <a class="item" href="<%= syzoj.utils.makeUrl(['user', user.id, 'edit']) %>"><i class="edit icon"></i>修改资料</a>
                  <a class="item" href="<%= syzoj.utils.makeUrl(['clipboard']) %>"><i class="clipboard outline icon"></i>我的剪贴板</a>
                  <% if (user.is_admin) { %>
                    <div class="ui divider"></div>
                    <a class="item" href="<%= syzoj.utils.makeUrl(['admin', 'info']) %>"><i class="settings icon"></i>后台管理</a>
                    <% if (user && user.is_admin) { %>
                        <form method="post" action="<%= syzoj.utils.makeUrl(['admin', 'recalc-hit-scores']) %>"
                              onsubmit="return confirm('确定立即重新计算所有用户的 Hit 值吗？这是后台异步任务，需要 10-30 秒。');"
                              style="margin: 0;">
                          <button type="submit" class="item" style="background: none; border: none; cursor: pointer; padding: 11px 16px; width: 100%; text-align: left; font-family: inherit; font-size: 1em; color: rgba(0,0,0,0.87); display: flex; align-items: center;">
                            <i class="refresh icon"></i>重算 Hit 值
                          </button>
                        </form>
                    <% } %>
                    <div class="ui basic modal" id="modal-restart">
                      <div class="ui icon header">
                        <i class="redo icon"></i>
                        <p style="margin-top: 15px; ">重启服务</p>
                      </div>
                      <div class="content" style="text-align: center; ">
                        <p>确认重新启动 SYZOJ Web 服务吗？</p>
                      </div>
                      <div class="actions">
                        <div class="ui red basic cancel inverted button">
                          <i class="remove icon"></i>
                          否
                        </div>
                        <a class="ui green ok inverted button" href-post="<%= syzoj.utils.makeUrl(['admin', 'restart'], { url: req.query['url'] || req.originalUrl }) %>">
                          <i class="checkmark icon"></i>
                          是
                        </a>
                      </div>
                    </div>
                    <a class="item" href="#" onclick="$('#modal-restart').modal('show')"><i class="redo icon"></i>重启服务</a>
                  <% } %>
                  <% if (user.is_admin || (user.privileges && user.privileges.includes('manage_problem'))) { %>
                    <a class="item" href="<%= syzoj.utils.makeUrl(['admin', 'solutions']) %>"><i class="gavel icon"></i>题解审核</a>
                  <% } %>
                  <% if (user.is_admin) { %>
                    <a class="item" href="<%= syzoj.utils.makeUrl(['admin', 'announcements']) %>"><i class="bullhorn icon"></i>公告管理</a>
                    <a class="item" href="<%= syzoj.utils.makeUrl(['admin', 'user-tags']) %>"><i class="id badge icon"></i>牌子管理</a>
                  <% } %>
                  <a class="item" href-post="<%= syzoj.utils.makeUrl(['logout'], { url: req.originalUrl }) %>"><i class="power icon"></i>注销</a>
                </div>
              </div>
              </a>
                <% } else { %>
                <div class="item">
                    <a class="ui button" style="margin-right: 0.5em; " href="<%= syzoj.utils.makeUrl(['login'], { url: req.query['url'] || req.originalUrl }) %>">
                        登录
                    </a>
                    <a class="ui primary button" href="<%= syzoj.utils.makeUrl(['sign_up'], { url: req.query['url'] || req.originalUrl }) %>">
                        注册
                    </a>
                </div>
                <% } %>
            </div>
        </div>
    </div>
    <div style="margin-top: 28px; ">
    <div class="ui main container">
