<% this.title = '排名' %>
<% include header %>
<div class="padding">
  <form action="<%= syzoj.utils.makeUrl(['find_user']) %>" class="ui mini form" method="get" role="form" style="margin-bottom: 25px; text-align: right; ">
    <div class="ui action left icon input inline" style="width: 180px; margin-right: 77px; ">
      <i class="search icon"></i><input name="nickname" placeholder="用户名" type="text">
      <button class="ui mini button" type="submit">查找用户</button>
    </div>
  </form>

  <%
  let isHitMode = (curSort === 'hit');
  %>
  <div class="ui top attached tabular menu" style="margin-bottom: 0;">
    <a class="item <% if (!isHitMode) { %>active<% } %>" href="<%= syzoj.utils.makeUrl(['ranklist']) %>">
      <i class="star icon"></i> Rating 排名
    </a>
    <a class="item <% if (isHitMode) { %>active<% } %>" href="<%= syzoj.utils.makeUrl(['ranklist'], { sort: 'hit', order: 'desc' }) %>">
      <i class="bullseye icon"></i> Hit 值排名
    </a>
  </div>

  <div class="ui bottom attached segment" style="border-top: none; padding: 18px 12px;">
            <table class="ui very basic center aligned table" style="table-layout: fixed; margin: 0;">
                <thead>
                <tr>
                    <th style="width: 60px; ">#</th>
                    <th style="width: 150px; "><%- createSortableTitle('username', '用户名', true) %></th>
                    <th>个性签名</th>
                    <% if (isHitMode) { %>
                      <th style="width: 100px; ">通过数量</th>
                      <th style="width: 100px; ">Hit 值</th>
                    <% } else { %>
                      <th style="width: 100px; "><%- createSortableTitle('ac_num', '通过数量', false) %></th>
                      <th style="width: 100px; "><%- createSortableTitle('rating', '积分', false) %></th>
                    <% } %>
                </tr>
                </thead>
          <script data-cfasync="false">
          var lineHeight = 0;
          (function () {
            var div = document.createElement('div');
            div.style.position = 'fixed';
            div.style.left = -10000;
            div.style.visibility = 'hidden';
            div.innerText = '测试，Test.';
            document.body.appendChild(div);
            lineHeight = div.clientHeight;
          })();
          </script>
                <tbody>
                <%
            let i = (paginate.currPage - 1) * paginate.perPage;
            for (let user of ranklist) {
              ++i;
              // 计算 Hit 值显示(优先用路由层 join 出的 __hitTotal,否则查内存 Map)
              let hitValue = 0;
              if (typeof user.__hitTotal !== 'undefined') {
                hitValue = user.__hitTotal;
              } else if (syzoj.userHitScores && syzoj.userHitScores.has(user.id)) {
                hitValue = syzoj.userHitScores.get(user.id).total || 0;
              }
              // Hit 值的 tier 颜色,用于显示
              let hitTier = 'gray';
              if (user.is_admin) hitTier = 'admin';
              else if (syzoj.adminUserIds && syzoj.adminUserIds.has(user.id)) hitTier = 'admin';
              else if (hitValue >= 350) hitTier = 'red';
              else if (hitValue >= 280) hitTier = 'orange';
              else if (hitValue >= 200) hitTier = 'green';
              else if (hitValue >= 100) hitTier = 'blue';
            %>
            <tr>
                                <td><b><%= i %></b></td>
                                <td><%- syzoj.utils.renderUsername(user) %></td>
                                <td class="font-content">
              <script id="user-infomation-script-<%= i %>" data-cfasync="false">
              (function () {
                var html = <%- serializejs(user.information) %>;
                var elem = document.createElement('div');
                elem.style = 'overflow: hidden; width: 100%; position: relative; ';
                elem.style.maxHeight = lineHeight + 'px';
                elem.innerHTML = html;
                var imgs = Array.prototype.slice.call(elem.getElementsByTagName('img'));
                for (var i in imgs) imgs[i].parentNode.removeChild(imgs[i]);
                var script = document.getElementById('user-infomation-script-<%= i %>');
                script.parentNode.replaceChild(elem, script);
              })();
              </script>
              </td>
                                <td><%= user.ac_num %></td>
                                <% if (isHitMode) { %>
                                  <td><span class="username-tier-<%= hitTier %>" style="font-weight: bold;"><%= hitValue %></span></td>
                                <% } else { %>
                                  <td><%= user.rating %></td>
                                <% } %>
                        </tr>
                    <% } %>
                </tbody>
            </table>
  </div>
    <br>
<% include page %>
</div>
<% include footer %>